[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.5
reloadable = true

[libraries]
macos.editor.arm64="res://native/target/aarch64-apple-darwin/debug/libeditor.dylib"
macos.editor.x86_64="res://native/target/x86_64-apple-darwin/debug/libeditor.dylib"
windows.editor.x86_64="res://native/target/x86_64-pc-windows-msvc/debug/editor.dll"
linux.editor.x86_64="res://native/target/x86_64-unknown-linux-gnu/debug/libeditor.so"
